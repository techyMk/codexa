# ────────────────────────────────────────────────────────────
# Codexa — root environment template
# Copy to .env (root), backend/.env, frontend/.env.local as noted
# ────────────────────────────────────────────────────────────

# ── GitHub App (create at https://github.com/settings/apps/new) ──
GITHUB_APP_ID=123456
GITHUB_APP_CLIENT_ID=Iv1.xxxxxxxxxxxx
GITHUB_APP_CLIENT_SECRET=xxxxxxxxxxxx
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=generate-a-long-random-string

# ── AI providers (both free) ──
# Gemini: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIzaSy...
# Groq: https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# ── Supabase (free) — https://supabase.com/dashboard ──
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# ── App ──
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
